# Coller dans le Caddyfile du projet AQOJ (frontal qui détient les ports 80/443).
# Remplacer poopedex.example.com par ton vrai domaine.

poopedex.example.com {
    encode zstd gzip
    reverse_proxy poopedex-web:80
}

api.poopedex.example.com {
    encode zstd gzip
    reverse_proxy poopedex-api:3000
}
