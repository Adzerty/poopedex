# Domaine de base — deux records DNS A à pointer vers le VPS :
#   poopedex.example.com       (PWA)
#   api.poopedex.example.com   (API)
DOMAIN=poopedex.example.com

# Email pour Let's Encrypt (notifications expiration, etc.)
ACME_EMAIL=admin@example.com

# Postgres (db non exposée à l'extérieur du réseau compose)
POSTGRES_PASSWORD=changeme-strong-password

# Secret JWT — min 16 chars (cf. api/src/config.ts), vise 64+ aléatoires :
#   openssl rand -hex 48
JWT_SECRET=replace-me-with-a-long-random-secret
