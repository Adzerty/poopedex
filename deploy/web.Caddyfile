:80 {
    root * /srv/web
    encode zstd gzip

    @assets path /assets/*
    header @assets Cache-Control "public, max-age=31536000, immutable"

    @nocache path /sw.js /service-worker.js /manifest.webmanifest /registerSW.js
    header @nocache Cache-Control "no-cache"

    try_files {path} /index.html
    file_server
}
