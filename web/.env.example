# URL de l'API. Laissée vide => déduite de l'hôte du front (même machine, port 3000),
# donc marche en local ET depuis un téléphone sur le LAN sans config.
# Décommente seulement si l'API est sur une autre machine/port.
# VITE_API_URL=http://localhost:3000

# Style MapLibre. Défaut : OpenFreeMap (tuiles OSM vectorielles, sans clé).
# Alternatives : MapTiler (https://api.maptiler.com/maps/streets/style.json?key=XXX)
VITE_MAP_STYLE=https://tiles.openfreemap.org/styles/liberty
